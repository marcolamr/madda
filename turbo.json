{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "APP_LOCALE",
    "APP_FALLBACK_LOCALE",
    "ARGON_MEMORY",
    "ARGON_THREADS",
    "ARGON_TIME",
    "BCRYPT_LIMIT",
    "BCRYPT_ROUNDS",
    "DB_CONNECTION",
    "DB_DATABASE",
    "DB_HOST",
    "DB_PORT",
    "DB_USERNAME",
    "DB_PASSWORD",
    "HASH_DRIVER",
    "HASH_REHASH_ON_LOGIN",
    "HASH_VERIFY",
    "NODE_ENV"
  ],
  "globalPassThroughEnv": [
    "PLAYGROUND_WEB",
    "PORT",
    "APP_NAME",
    "APP_ENV",
    "APP_DEBUG",
    "ARGON_MEMORY",
    "ARGON_THREADS",
    "ARGON_TIME",
    "BCRYPT_LIMIT",
    "BCRYPT_ROUNDS",
    "HASH_DRIVER",
    "HASH_REHASH_ON_LOGIN",
    "HASH_VERIFY",
    "NODE_ENV",
    "APP_URL",
    "APP_KEY",
    "APP_PREVIOUS_KEYS",
    "APP_LOCALE",
    "APP_FALLBACK_LOCALE",
    "LOG_CHANNEL",
    "LOG_STACK",
    "LOG_LEVEL",
    "LOG_PATH",
    "LOG_HTTP_REQUEST_TIMING",
    "LOG_HTTP_TIMING_STATE_KEY",
    "LOG_HTTP_ACCESS",
    "LOG_SLACK_WEBHOOK_URL",
    "PAPERTRAIL_URL",
    "PAPERTRAIL_PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".vitepress/dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
