{
  "name": "madda_v1",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "create-app": "pnpm --filter create-madda-app build && pnpm exec create-madda-app",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm exec turbo run build --filter=create-madda-app && changeset publish",
    "release": "pnpm run changeset:publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "create-madda-app": "workspace:*",
    "prettier": "^3.7.4",
    "turbo": "^2.9.3",
    "typescript": "5.9.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
