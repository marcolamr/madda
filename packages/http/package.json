{
  "name": "@madda/http",
  "version": "0.0.3",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/inject-http.d.ts",
      "import": "./dist/testing/inject-http.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run"
  },
  "dependencies": {
    "@madda/container": "workspace:*",
    "@madda/jsonschema": "workspace:*",
    "@madda/log": "workspace:*",
    "@madda/reflection": "workspace:*",
    "fastify": "^5.2.1",
    "light-my-request": "^6.6.0",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@madda/eslint-config": "workspace:*",
    "@madda/testing": "workspace:*",
    "@madda/typescript-config": "workspace:*",
    "@types/node": "^25.5.2",
    "eslint": "^9.39.1",
    "typescript": "5.9.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
