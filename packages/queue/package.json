{
  "name": "@madda/queue",
  "version": "0.0.3",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run"
  },
  "dependencies": {
    "@madda/config": "workspace:*",
    "@madda/container": "workspace:*",
    "@madda/database": "workspace:*",
    "@madda/events": "workspace:*",
    "@madda/redis": "workspace:*"
  },
  "devDependencies": {
    "@madda/eslint-config": "workspace:*",
    "@madda/testing": "workspace:*",
    "@madda/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "typescript": "5.9.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
