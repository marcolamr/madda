# Copy to `.env` and adjust. Generate APP_KEY with: pnpm madda key:generate
APP_NAME=Madda Playground
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:3333
APP_KEY=
APP_PREVIOUS_KEYS=

APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

PORT=3333

DB_CONNECTION=sqlite
DB_DATABASE=database/db.sqlite

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_LEVEL=debug
LOG_PATH=./storage/logs/laravel.log
LOG_DAILY_DAYS=14
LOG_STACK_IGNORE_EXCEPTIONS=false
LOG_DEPRECATIONS_CHANNEL=null
LOG_DEPRECATIONS_TRACE=false
LOG_HTTP_REQUEST_TIMING=true
LOG_HTTP_ACCESS=true

# After `pnpm madda config:publish hashing` — optional overrides (see config/hashing.ts)
# HASH_DRIVER=argon2id
# HASH_VERIFY=true
# BCRYPT_ROUNDS=12
# ARGON_MEMORY=65536
# ARGON_THREADS=1
# ARGON_TIME=4
# HASH_REHASH_ON_LOGIN=true
