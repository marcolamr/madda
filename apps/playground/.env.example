# Copy to `.env` and adjust. Generate APP_KEY with: pnpm madda key:generate
APP_NAME=Madda Playground
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:3333
APP_KEY=
APP_PREVIOUS_KEYS=

APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

PORT=3333

DB_CONNECTION=sqlite
DB_DATABASE=database/db.sqlite

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_LEVEL=debug
